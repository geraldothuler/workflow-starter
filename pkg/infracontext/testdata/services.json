        "clusterIP": "10.96.100.4",
        "ports": [
          { "name": "http", "port": 80, "protocol": "TCP", "targetPort": 3000 },
          { "name": "https", "port": 443, "protocol": "TCP", "targetPort": 3000 }
        ],
        "selector": {
          "app": "frontend"
        }
      }
    }
