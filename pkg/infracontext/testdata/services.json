{
  "apiVersion": "v1",
  "kind": "ServiceList",
  "items": [
    {
      "metadata": {
        "name": "api-server",
        "namespace": "default",
        "labels": {
          "app": "api-server"
        }
      },
      "spec": {
        "type": "ClusterIP",
        "clusterIP": "10.96.100.1",
        "ports": [
          { "name": "http", "port": 8080, "protocol": "TCP", "targetPort": 8080 }
        ],
        "selector": {
          "app": "api-server"
        }
      }
    },
    {
      "metadata": {
        "name": "postgres",
        "namespace": "default",
        "labels": {
          "app": "postgres"
        }
      },
      "spec": {
        "type": "ClusterIP",
        "clusterIP": "10.96.100.2",
        "ports": [
          { "name": "pg", "port": 5432, "protocol": "TCP", "targetPort": 5432 }
        ],
        "selector": {
          "app": "postgres"
        }
      }
    },
    {
      "metadata": {
        "name": "redis-cache",
        "namespace": "default",
        "labels": {
          "app": "redis-cache"
        }
      },
      "spec": {
        "type": "ClusterIP",
        "clusterIP": "10.96.100.3",
        "ports": [
          { "name": "redis", "port": 6379, "protocol": "TCP", "targetPort": 6379 }
        ],
        "selector": {
          "app": "redis-cache"
        }
      }
    },
    {
      "metadata": {
